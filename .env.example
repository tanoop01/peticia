# ========================================
# PETICIA - Environment Variables
# ========================================

# =-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=
# FIREBASE CONFIGURATION (Required)
# =-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=
# Get these from: Firebase Console → Project Settings → General → Your apps
# https://console.firebase.google.com/

NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ⚠️ IMPORTANT: SMS OTP Configuration
# ══════════════════════════════════════
# LOCAL DEVELOPMENT (localhost):
#   - Real SMS won't work (Firebase security restriction)
#   - Use test numbers: Firebase Console → Authentication → Phone → Phone numbers for testing
#   - Example: +91 83189 15519 → OTP: 123456
#
# PRODUCTION (deployed on Vercel):
#   - Real SMS works automatically
#   - MUST add domain to: Firebase Console → Authentication → Settings → Authorized domains
#   - Required: Firebase billing enabled for production SMS
#   - Cost: ~₹0.50-1.00 per SMS in India


# =-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=
# SUPABASE CONFIGURATION (Required)
# =-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=
# Get these from: Supabase Dashboard → Project Settings → API
# https://app.supabase.com/

# For LOCAL development:
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_local_anon_key_from_supabase_status
SUPABASE_SERVICE_ROLE_KEY=your_local_service_role_key_from_supabase_status

# For PRODUCTION (copy these to Vercel environment variables):
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 🔒 SECURITY WARNING:
# - SUPABASE_SERVICE_ROLE_KEY bypasses all RLS policies
# - NEVER expose this key in client-side code
# - Only use in API routes (server-side)
# - Keep this secret and rotate if compromised


# =-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=
# AI CONFIGURATION (Required)
# =-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=
# Get your API key from: https://console.groq.com/
# Used for: AI Assistant, Petition Generation, Legal Guidance

GROQ_API_KEY=your_groq_api_key


# =-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=
# APPLICATION CONFIGURATION (Required)
# =-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=

# For LOCAL development:
NEXT_PUBLIC_APP_URL=http://localhost:3000

# For PRODUCTION (update after Vercel deployment):
# NEXT_PUBLIC_APP_URL=https://your-app-name.vercel.app

# Application name (displayed in UI):
NEXT_PUBLIC_APP_NAME=PETICIA


# =-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=
# EMAIL CONFIGURATION (Optional)
# =-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=
# Only needed if implementing email notifications
# For Gmail: Enable 2FA and generate App Password
# https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password


# =-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=
# DEPLOYMENT CHECKLIST
# =-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=
# Before deploying to Vercel:
# 
# [ ] Get Firebase config from Firebase Console
# [ ] Enable Firebase Phone Authentication
# [ ] Enable Firebase Billing (required for production SMS)
# [ ] Get Supabase production URL and keys
# [ ] Get Groq API key
# [ ] Add all variables to Vercel Environment Variables
# [ ] Deploy and get Vercel URL
# [ ] Add Vercel domain to Firebase Authorized domains
# [ ] Test SMS OTP with real phone number
#
# See DEPLOYMENT_GUIDE.md for detailed instructions
